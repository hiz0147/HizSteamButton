{
    "manifest_version": 3,
    "name": "HizSearch Steam Button",
    "version": "1.5.0",
    "description": "Search the current game on HizSearch",
    "author": "HizSearch",
    "homepage_url": "https://hizsearch.pages.dev",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_popup": "popup/popup.html",
        "default_title": "HizSearch Steam Button"
    },
    "options_ui": {
        "page": "popup/popup.html",
        "open_in_tab": false
    },
    "permissions": ["storage"],
    "content_scripts": [
        {
            "matches": [
                "https://store.steampowered.com/app/*",
                "https://steamdb.info/app/*"
            ],
            "js": ["content.js"],
            "run_at": "document_end"
        }
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "@hizsearch-steam-button",
            "strict_min_version": "142.0",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    }
}
